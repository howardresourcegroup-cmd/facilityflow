#!/usr/bin/env bash
#
# FacilityFlow secret-scanning pre-commit hook (dependency-free, macOS/Linux).
# Blocks a commit if a staged change looks like it contains a credential.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Bypass in a true emergency:  git commit --no-verify   (avoid this)

set -uo pipefail

RED=$'\033[0;31m'; YEL=$'\033[1;33m'; GRN=$'\033[0;32m'; NC=$'\033[0m'

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

violations=0

# ─── Block committing real env files ──────────────────────────────────────────
while IFS= read -r file; do
  [ -z "$file" ] && continue
  base=$(basename "$file")
  case "$base" in
    .env|.env.local|.env.production|.env.development)
      echo "${RED}✖ Blocked:${NC} attempting to commit an env file → ${YEL}$file${NC}"
      echo "  Env files hold secrets and must never be committed."
      violations=$((violations+1))
      ;;
  esac
done <<< "$staged"

# Added lines only (exclude the +++ header lines)
added=$(git diff --cached --diff-filter=ACM -U0 | grep '^+' | grep -v '^+++' || true)

# ─── Secret value patterns. Bounded intervals for BSD-grep compatibility. ─────
# label::regex   (regex passed with -e so leading dashes are safe)
scan() {
  local label="$1" regex="$2" hits
  hits=$(printf '%s\n' "$added" | grep -niE -e "$regex" 2>/dev/null || true)
  if [ -n "$hits" ]; then
    echo "${RED}✖ Possible ${label}:${NC}"
    printf '%s\n' "$hits" | head -2 | cut -c1-90 | sed 's/^/    /'
    violations=$((violations+1))
  fi
}

scan "GitHub token"            'gh[opsu]_[A-Za-z0-9]{36,255}'
scan "GitHub fine-grained PAT" 'github_pat_[A-Za-z0-9_]{60,255}'
scan "Stripe secret key"       'sk_live_[A-Za-z0-9]{20,255}'
scan "Stripe restricted key"   'rk_live_[A-Za-z0-9]{20,255}'
scan "AWS access key id"       'AKIA[0-9A-Z]{16}'
scan "Google API key"          'AIza[0-9A-Za-z_-]{35}'
scan "Slack token"             'xox[baprs]-[A-Za-z0-9-]{10,255}'
scan "Private key block"       'BEGIN [A-Z ]*PRIVATE KEY'
scan "JWT / service_role key"  'eyJ[A-Za-z0-9_-]{15,}\.eyJ[A-Za-z0-9_-]{15,}\.[A-Za-z0-9_-]{10,}'
scan "Hardcoded secret assign" '(secret|api[_-]?key|access[_-]?token|client[_-]?secret|password)["'"'"' ]*[:=]["'"'"' ]+[A-Za-z0-9_+/-]{16,}'

if [ "$violations" -gt 0 ]; then
  echo "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo "${RED} Commit blocked: $violations potential secret(s) found.${NC}"
  echo " Move the value into an env var and use process.env.* instead."
  echo " False positive? Bypass once with: git commit --no-verify"
  echo "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  exit 1
fi

echo "${GRN}✓ Secret scan passed${NC}"
exit 0
