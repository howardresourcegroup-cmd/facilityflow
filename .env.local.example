# Supabase — get these from your Supabase project settings > API
# Set NEXT_PUBLIC_* as PLAINTEXT (not Secret) in Cloudflare — they must be available at build time.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret   # keep as a Secret; server-only

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (billing) — from dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx   # plaintext; safe in browser
STRIPE_SECRET_KEY=sk_live_or_test_xxx                    # Secret; server-only
STRIPE_PRICE_ID=price_xxx                                # standard $299/mo price
STRIPE_PRICE_ID_LARGE=price_xxx                          # optional: $399/mo price, auto-used for 25+ user orgs
STRIPE_WEBHOOK_SECRET=whsec_xxx                          # from the webhook endpoint you create
